{
  "name": "postgres-jdbc-sink",
  "config": {
    "connector.class": "io.debezium.connector.jdbc.JdbcSinkConnector",
    "tasks.max": "1",
    
    "connection.url": "jdbc:postgresql://postgres-target:5432/dstdb",
    "connection.username": "dst_user",
    "connection.password": "dst_pass",
    
    "topics.regex": "src_server\\.public\\..*",
    
    "insert.mode": "upsert",
    "delete.enabled": "true",
    "primary.key.mode": "record_key",
    "primary.key.fields": "id",
    
    "schema.evolution": "basic",
    
    "transforms": "route",
    "transforms.route.type": "org.apache.kafka.connect.transforms.RegexRouter",
    "transforms.route.regex": "src_server\\.public\\.(.*)",
    "transforms.route.replacement": "$1",
    
    "table.name.format": "${topic}"
  }
}